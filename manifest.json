{
  "manifest_version": 3,
  "name": "GDrive Sidebar Pinner",
  "version": "1.0.0",
  "description": "Pin Google Drive folders in a native-looking sidebar, with folder colors preserved and synced across Chrome.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["*://drive.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ]
}
